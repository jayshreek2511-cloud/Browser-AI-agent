APP_NAME=General Browser AI Agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite+aiosqlite:///./agent.db
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL_PLANNER=gemini-2.5-flash
GEMINI_MODEL_WORKER=gemini-2.5-flash
GEMINI_MODEL_FINAL=gemini-2.5-pro
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
MAX_WEB_SOURCES=5
MAX_VIDEO_RESULTS=5
SCREENSHOT_DIR=artifacts/screenshots
ALLOW_LIVE_BROWSER=true
